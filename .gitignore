# Ignore AWS CLI zip and installation files
awscliv2.zip

# Ignore everything under the aws/ directory, except for specific bash scripts
aws/
!aws/s3/bash-scripts/

# Local .terraform directories (generated during Terraform operations)
**/.terraform/*

# Terraform state files, which may contain sensitive information
*.tfstate
*.tfstate.*

# Ignore crash log files that may contain debugging information
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# passwords, private keys, and other secrets. These should not be part of version 
# control as they are data points that are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore AWS CLI zip and installation files
awscliv2.zip

# Ignore everything under the aws/ directory, except for specific bash scripts and folders
aws/
!aws/s3/bash-scripts/
!aws/s3/new-scripts/   # Add this if you have a new subfolder to include
!aws/bin/aws_cli_install.sh
!aws/bin/terraform_cli_install.sh

# Local .terraform directories (generated during Terraform operations)
**/.terraform/*

# Terraform state files, which may contain sensitive information
*.tfstate
*.tfstate.*

# Ignore crash log files that may contain debugging information
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json



